{
  "name": "backend",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:pretty": "wrangler dev | pino-pretty",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:generate": "drizzle-kit generate",
    "db:migrate-local": "wrangler d1 migrations apply webmarks --local",
    "db:migrate-remote": "wrangler d1 migrations apply webmarks --remote",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "type:check": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.3.0",
    "better-auth": "^1.6.9",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.15",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "wrangler": "^4.4.0"
  }
}
